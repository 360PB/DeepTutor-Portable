# ============================================
# DeepTutor Environment Configuration
# ============================================
# Copy this file to .env and fill in your API keys.

# --------------------------------------------
# Ports
# --------------------------------------------
BACKEND_PORT=8001
FRONTEND_PORT=3782

# --------------------------------------------
# LLM (Required)
# --------------------------------------------
# Supported: openai, lm_studio, ollama, deepseek, anthropic, dashscope, ...
LLM_BINDING=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-xxx
LLM_HOST=https://api.openai.com/v1
LLM_API_VERSION=

# --------------------------------------------
# Embedding (Required for knowledge base features)
# --------------------------------------------
EMBEDDING_BINDING=openai
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_API_KEY=sk-xxx
EMBEDDING_HOST=https://api.openai.com/v1
EMBEDDING_DIMENSION=3072
EMBEDDING_API_VERSION=

# Local LLM example (LM Studio):
# LLM_BINDING=lm_studio
# LLM_HOST=http://localhost:1234/v1
# EMBEDDING_BINDING=lm_studio
# EMBEDDING_HOST=http://localhost:1234/v1

# --------------------------------------------
# Web Search (Optional)
# --------------------------------------------
SEARCH_PROVIDER=
SEARCH_API_KEY=
SEARCH_BASE_URL=

# --------------------------------------------
# Security / Networking (Optional)
# --------------------------------------------
DISABLE_SSL_VERIFY=false
